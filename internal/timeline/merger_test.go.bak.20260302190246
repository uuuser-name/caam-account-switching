func TestDeduplication(t *testing.T) {
	m := NewMerger()
	m.DeduplicateByTimestamp = true

	// Duplicate events with same timestamp and step_id
	events := []*LogEvent{
		makeEvent("run-1", "scenario-a", "step-1", "2024-01-01T10:00:00Z"),
		makeEvent("run-1", "scenario-a", "step-1", "2024-01-01T10:00:00Z"), // duplicate
		makeEvent("run-1", "scenario-a", "step-2", "2024-01-01T10:00:01Z"),
	}

	result, err := m.MergeEvents(events, MergeStats{})
	if err != nil {
		t.Fatalf("MergeEvents failed: %v", err)
	}

	timeline := result.Timelines["scenario-a"]
	if len(timeline.Events) != 2 {
		t.Errorf("Expected 2 events after deduplication, got %d", len(timeline.Events))
	}

	if result.Stats.DuplicatesRemoved != 1 {
		t.Errorf("Expected 1 duplicate removed, got %d", result.Stats.DuplicatesRemoved)
	}
}

