func TestTimelineMetadata(t *testing.T) {
	m := NewMerger()
	events := []*LogEvent{
		makeEvent("run-1", "scenario-a", "step-1", "2024-01-01T10:00:00Z"),
		makeEvent("run-1", "scenario-a", "step-2", "2024-01-01T10:00:05Z"),
		makeEventWithError("run-1", "scenario-a", "step-3", "2024-01-01T10:00:10Z"),
	}

	result, err := m.MergeEvents(events, MergeStats{})
	if err != nil {
		t.Fatalf("MergeEvents failed: %v", err)
	}

	timeline := result.Timelines["scenario-a"]
	meta := timeline.Metadata

	if meta.TotalEvents != 3 {
		t.Errorf("Expected TotalEvents=3, got %d", meta.TotalEvents)
	}

	if meta.StartTime != "2024-01-01T10:00:00Z" {
		t.Errorf("Expected StartTime='2024-01-01T10:00:00Z', got %s", meta.StartTime)
	}

	if meta.EndTime != "2024-01-01T10:00:10Z" {
		t.Errorf("Expected EndTime='2024-01-01T10:00:10Z', got %s", meta.EndTime)
	}

	if meta.ErrorCount != 1 {
		t.Errorf("Expected ErrorCount=1, got %d", meta.ErrorCount)
	}

	// TotalDurationMs should be 100 + 100 + 100 = 300
	if meta.TotalDurationMs != 300 {
		t.Errorf("Expected TotalDurationMs=300, got %d", meta.TotalDurationMs)
	}
}

