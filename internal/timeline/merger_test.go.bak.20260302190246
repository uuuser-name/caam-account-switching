func TestWriteJSONL(t *testing.T) {
	m := NewMerger()
	events := []*LogEvent{
		makeEvent("run-1", "scenario-a", "step-1", "2024-01-01T10:00:00Z"),
		makeEvent("run-1", "scenario-b", "step-1", "2024-01-01T10:00:01Z"),
	}

	result, err := m.MergeEvents(events, MergeStats{})
	if err != nil {
		t.Fatalf("MergeEvents failed: %v", err)
	}

	var buf bytes.Buffer
	if err := result.WriteJSONL(&buf); err != nil {
		t.Fatalf("WriteJSONL failed: %v", err)
	}

	// Should have 2 lines (one per timeline)
	lines := strings.Split(strings.TrimSpace(buf.String()), "\n")
	if len(lines) != 2 {
		t.Errorf("Expected 2 lines, got %d", len(lines))
	}

	// Each line should be valid JSON
	for i, line := range lines {
		var timeline Timeline
		if err := json.Unmarshal([]byte(line), &timeline); err != nil {
			t.Errorf("Line %d is not valid JSON: %v", i, err)
		}
	}
}