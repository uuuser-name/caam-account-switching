func TestParseJSONLReader(t *testing.T) {
	m := NewMerger()
	jsonl := `{"run_id":"run-1","scenario_id":"scenario-a","step_id":"step-1","timestamp":"2024-01-01T10:00:00Z","actor":"ci","component":"test","input_redacted":{},"output":{},"decision":"pass","duration_ms":100,"error":{"present":false,"code":"","message":"","details":{}}}
{"run_id":"run-1","scenario_id":"scenario-a","step_id":"step-2","timestamp":"2024-01-01T10:00:01Z","actor":"ci","component":"test","input_redacted":{},"output":{},"decision":"pass","duration_ms":200,"error":{"present":false,"code":"","message":"","details":{}}}`

	events, parseErrors, err := m.parseJSONLReader(strings.NewReader(jsonl), "test.jsonl")
	if err != nil {
		t.Fatalf("parseJSONLReader failed: %v", err)
	}
	if parseErrors != 0 {
		t.Errorf("Expected 0 parse errors, got %d", parseErrors)
	}
	if len(events) != 2 {
		t.Errorf("Expected 2 events, got %d", len(events))
	}
}

