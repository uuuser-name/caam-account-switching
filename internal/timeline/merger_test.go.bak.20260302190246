func makeEvent(runID, scenarioID, stepID, timestamp string) *LogEvent {
	return &LogEvent{
		RunID:      runID,
		ScenarioID: scenarioID,
		StepID:     stepID,
		Timestamp:  timestamp,
		Actor:      "ci",
		Component:  "test",
		Decision:   "pass",
		DurationMs: 100,
		Error:      ErrorEnvelope{Present: false},
	}
}

func makeEventWithComponent(runID, scenarioID, stepID, timestamp, component string) *LogEvent {
	e := makeEvent(runID, scenarioID, stepID, timestamp)
	e.Component = component
	return e
}

func makeEventWithError(runID, scenarioID, stepID, timestamp string) *LogEvent {
	e := makeEvent(runID, scenarioID, stepID, timestamp)
	e.Error = ErrorEnvelope{
		Present: true,
		Code:    "ERR_TEST",
		Message: "test error",
	}
	return e
}

