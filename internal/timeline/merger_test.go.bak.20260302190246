// =============================================================================
// Determinism Tests (Critical for Acceptance Criteria)
// =============================================================================

func TestMergeDeterminism(t *testing.T) {
	// Create events with the same timestamps but added in different orders
	// The output should be identical regardless of input order
	events1 := []*LogEvent{
		makeEvent("run-1", "scenario-a", "step-3", "2024-01-01T10:00:02Z"),
		makeEvent("run-1", "scenario-a", "step-1", "2024-01-01T10:00:00Z"),
		makeEvent("run-1", "scenario-a", "step-2", "2024-01-01T10:00:01Z"),
		makeEvent("run-1", "scenario-b", "step-2", "2024-01-01T10:00:01Z"),
		makeEvent("run-1", "scenario-b", "step-1", "2024-01-01T10:00:00Z"),
	}

	events2 := []*LogEvent{
		makeEvent("run-1", "scenario-b", "step-1", "2024-01-01T10:00:00Z"),
		makeEvent("run-1", "scenario-a", "step-2", "2024-01-01T10:00:01Z"),
		makeEvent("run-1", "scenario-a", "step-1", "2024-01-01T10:00:00Z"),
		makeEvent("run-1", "scenario-b", "step-2", "2024-01-01T10:00:01Z"),
		makeEvent("run-1", "scenario-a", "step-3", "2024-01-01T10:00:02Z"),
	}

	m := NewMerger()
	result1, err := m.MergeEvents(events1, MergeStats{})
	if err != nil {
		t.Fatalf("MergeEvents 1 failed: %v", err)
	}

	result2, err := m.MergeEvents(events2, MergeStats{})
	if err != nil {
		t.Fatalf("MergeEvents 2 failed: %v", err)
	}

	// Serialize both results to JSONL and compare
	var buf1, buf2 bytes.Buffer
	if err := result1.WriteMergedJSONL(&buf1); err != nil {
		t.Fatalf("WriteMergedJSONL 1 failed: %v", err)
	}
	if err := result2.WriteMergedJSONL(&buf2); err != nil {
		t.Fatalf("WriteMergedJSONL 2 failed: %v", err)
	}

	if buf1.String() != buf2.String() {
		t.Errorf("Determinism violation: same events in different order produced different outputs")
		t.Errorf("Output 1:\n%s", buf1.String())
		t.Errorf("Output 2:\n%s", buf2.String())
	}
}

func TestMergeDeterminismWithSameTimestamp(t *testing.T) {
	// Events with identical timestamps should be sorted by step_id
	events := []*LogEvent{
		makeEventWithComponent("run-1", "scenario-a", "step-3", "2024-01-01T10:00:00Z", "component-c"),
		makeEventWithComponent("run-1", "scenario-a", "step-1", "2024-01-01T10:00:00Z", "component-a"),
		makeEventWithComponent("run-1", "scenario-a", "step-2", "2024-01-01T10:00:00Z", "component-b"),
	}

	m := NewMerger()
	result, err := m.MergeEvents(events, MergeStats{})
	if err != nil {
		t.Fatalf("MergeEvents failed: %v", err)
	}

	timeline := result.Timelines["scenario-a"]
	if len(timeline.Events) != 3 {
		t.Fatalf("Expected 3 events, got %d", len(timeline.Events))
	}

	// Events should be sorted by step_id when timestamps are equal
	expectedOrder := []string{"step-1", "step-2", "step-3"}
	for i, event := range timeline.Events {
		if event.StepID != expectedOrder[i] {
			t.Errorf("Event %d: expected step_id %s, got %s (same timestamp should sort by step_id)", i, expectedOrder[i], event.StepID)
		}
	}
}

func TestMergeDeterminismMultipleRuns(t *testing.T) {
	// Run the same merge operation multiple times, verify identical output
	events := []*LogEvent{
		makeEvent("run-1", "scenario-a", "step-1", "2024-01-01T10:00:00Z"),
		makeEvent("run-1", "scenario-a", "step-2", "2024-01-01T10:00:01Z"),
		makeEvent("run-1", "scenario-b", "step-1", "2024-01-01T10:00:00Z"),
		makeEvent("run-2", "scenario-a", "step-1", "2024-01-01T11:00:00Z"),
	}

	m := NewMerger()

	var outputs []string
	for i := 0; i < 5; i++ {
		result, err := m.MergeEvents(events, MergeStats{})
		if err != nil {
			t.Fatalf("MergeEvents run %d failed: %v", i, err)
		}

		var buf bytes.Buffer
		if err := result.WriteMergedJSONL(&buf); err != nil {
			t.Fatalf("WriteMergedJSONL run %d failed: %v", i, err)
		}
		outputs = append(outputs, buf.String())
	}

	// All outputs should be identical
	for i := 1; i < len(outputs); i++ {
		if outputs[i] != outputs[0] {
			t.Errorf("Run %d produced different output than run 0 (non-deterministic)", i)
		}
	}
}

