func TestMergeJSONLFiles(t *testing.T) {
	// Create temp files
	tmpDir := t.TempDir()
	file1 := filepath.Join(tmpDir, "events1.jsonl")
	file2 := filepath.Join(tmpDir, "events2.jsonl")

	// Write test data
	event1 := makeEvent("run-1", "scenario-a", "step-1", "2024-01-01T10:00:00Z")
	event2 := makeEvent("run-1", "scenario-b", "step-1", "2024-01-01T11:00:00Z")

	data1, _ := json.Marshal(event1)
	data2, _ := json.Marshal(event2)

	if err := os.WriteFile(file1, append(data1, '\n'), 0644); err != nil {
		t.Fatalf("Write file1: %v", err)
	}
	if err := os.WriteFile(file2, append(data2, '\n'), 0644); err != nil {
		t.Fatalf("Write file2: %v", err)
	}

	m := NewMerger()
	result, err := m.MergeJSONLFiles([]string{file1, file2})
	if err != nil {
		t.Fatalf("MergeJSONLFiles failed: %v", err)
	}

	if len(result.Timelines) != 2 {
		t.Errorf("Expected 2 timelines, got %d", len(result.Timelines))
	}

	if result.Stats.SourceFiles != 2 {
		t.Errorf("Expected SourceFiles=2, got %d", result.Stats.SourceFiles)
	}
}

func TestWriteMergedJSONLFile(t *testing.T) {
	m := NewMerger()
	events := []*LogEvent{
		makeEvent("run-1", "scenario-a", "step-1", "2024-01-01T10:00:00Z"),
		makeEvent("run-1", "scenario-a", "step-2", "2024-01-01T10:00:01Z"),
	}

	result, err := m.MergeEvents(events, MergeStats{})
	if err != nil {
		t.Fatalf("MergeEvents failed: %v", err)
	}

	tmpDir := t.TempDir()
	outputPath := filepath.Join(tmpDir, "merged.jsonl")

	if err := result.WriteMergedJSONLFile(outputPath); err != nil {
		t.Fatalf("WriteMergedJSONLFile failed: %v", err)
	}

	// Verify file exists and can be read back
	data, err := os.ReadFile(outputPath)
	if err != nil {
		t.Fatalf("Read output file: %v", err)
	}

	lines := strings.Split(strings.TrimSpace(string(data)), "\n")
	if len(lines) != 2 {
		t.Errorf("Expected 2 lines in output, got %d", len(lines))
	}
}

